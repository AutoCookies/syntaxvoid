{
    "name": "syntaxvoid-risk-overlay",
    "version": "0.1.0",
    "description": "Production-grade structural risk governance system for SyntaxVoid IDE",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc -p tsconfig.json"
    },
    "engines": {
        "atom": ">=1.0.0 <2.0.0"
    },
    "keywords": [
        "risk",
        "structural-analysis",
        "governance",
        "code-quality"
    ],
    "consumedServices": {
        "syntaxvoid-project-map.graph": {
            "versions": {
                "1.0.0": "consumeGraphService"
            }
        }
    },
    "providedServices": {
        "syntaxvoid-risk-overlay.evaluation": {
            "versions": {
                "1.0.0": "provideRiskEvaluationService"
            }
        }
    },
    "configSchema": {
        "policy": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "default": true,
                    "title": "Enable Risk Policy",
                    "description": "Enforce risk policies on patch proposals"
                },
                "maxAllowedRisk": {
                    "type": "number",
                    "default": 8.0,
                    "minimum": 0,
                    "maximum": 10,
                    "title": "Maximum Allowed Risk",
                    "description": "Maximum risk score before blocking (0-10)"
                },
                "blockCriticalNodes": {
                    "type": "boolean",
                    "default": false,
                    "title": "Block Critical Node Changes",
                    "description": "Prevent modifications to nodes with critical risk level"
                },
                "requireApprovalThreshold": {
                    "type": "number",
                    "default": 6.0,
                    "minimum": 0,
                    "maximum": 10,
                    "title": "Approval Threshold",
                    "description": "Risk score requiring explicit approval"
                }
            }
        },
        "computation": {
            "type": "object",
            "properties": {
                "depthCap": {
                    "type": "integer",
                    "default": 3,
                    "minimum": 1,
                    "maximum": 10,
                    "title": "BFS Depth Cap",
                    "description": "Maximum depth for centrality/radius computation"
                },
                "chunkSize": {
                    "type": "integer",
                    "default": 1000,
                    "minimum": 100,
                    "maximum": 10000,
                    "title": "Computation Chunk Size",
                    "description": "Number of nodes to process per chunk"
                }
            }
        }
    },
    "devDependencies": {
        "@types/atom": "^1.40.18",
        "@types/node": "^25.2.3",
        "syntaxvoid-project-map": "file:../syntaxvoid-project-map",
        "syntaxvoid-ui-kit": "file:../syntaxvoid-ui-kit",
        "typescript": "^5.9.3"
    }
}