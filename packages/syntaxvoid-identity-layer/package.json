{
    "name": "syntaxvoid-identity-layer",
    "version": "0.1.0",
    "description": "Provides Structural Identity, Status Bar metrics, and UX motion for SyntaxVoid.",
    "main": "dist/index.js",
    "activationHooks": [
        "core:loaded-shell-environment"
    ],
    "engines": {
        "atom": ">=1.0.0 <2.0.0"
    },
    "scripts": {
        "build": "tsc"
    },
    "consumedServices": {
        "status-bar": {
            "versions": {
                "^1.0.0": "consumeStatusBar"
            }
        },
        "syntaxvoid-risk-overlay": {
            "versions": {
                "^1.0.0": "consumeRiskOverlay"
            }
        }
    },
    "dependencies": {
        "syntaxvoid-ui-kit": "file:../syntaxvoid-ui-kit"
    },
    "devDependencies": {
        "@types/node": "^18.0.0",
        "typescript": "^4.9.0"
    }
}