{
    "name": "syntaxvoid-collab-struct",
    "version": "1.0.0",
    "description": "LAN-based structural collaboration for SyntaxVoid",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "license": "MIT",
    "engines": {
        "atom": ">=1.0.0 <2.0.0"
    },
    "dependencies": {
        "ws": "^8.16.0",
        "syntaxvoid-ui-kit": "file:../syntaxvoid-ui-kit"
    },
    "devDependencies": {
        "@types/ws": "^8.5.10",
        "@types/node": "^24.6.0",
        "@types/atom": "^1.40.18",
        "typescript": "^5.0.0"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json"
    },
    "activationCommands": {
        "atom-workspace": [
            "syntaxvoid-collab:host",
            "syntaxvoid-collab:join"
        ]
    },
    "consumedServices": {
        "syntaxvoid-project-map.graph": {
            "versions": {
                "1.0.0": "consumeProjectMap"
            }
        },
        "syntaxvoid-impact.graph": {
            "versions": {
                "1.0.0": "consumeImpact"
            }
        }
    }
}